<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="12dp"
    android:gravity="center_vertical"
    android:background="?android:attr/selectableItemBackground">

    <ImageView
        android:id="@+id/ivDragHandle"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:src="@drawable/ic_drag_white_24dp"
        app:tint="#666666"
        android:contentDescription="@string/reorder"
        android:importantForAccessibility="yes"
        android:clickable="true"
        android:focusable="true"/>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="8dp">

        <TextView
            android:id="@+id/tvTrackTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:maxLines="1"
            android:ellipsize="end"/>

        <TextView
            android:id="@+id/tvTrackArtist"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#AAAAAA"
            android:textSize="12sp"
            android:maxLines="1"
            android:ellipsize="end"/>

    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSongMenu"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:contentDescription="@string/cd_more_options"
        app:icon="@drawable/ic_more_vert_white_24dp"
        app:iconSize="24dp"
        app:iconTint="#BB86FC"
        android:background="?android:attr/selectableItemBackgroundBorderless"/>

</LinearLayout>