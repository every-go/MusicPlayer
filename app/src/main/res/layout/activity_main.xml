<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#121212">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <ImageButton
            android:id="@+id/btnPlayAll"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginEnd="10dp"
            android:src="@drawable/ic_play_white_24dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/cd_play_all"/>

        <TextView
            android:id="@+id/tvSongCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="8dp"
            android:text="@string/song_count"
            android:textColor="#AAAAAA"
            android:textSize="14sp"
            android:visibility="gone"/>

        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1"/>

        <ImageButton
            android:id="@+id/btnSearch"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_search_white_24dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/cd_search"/>

        <ImageButton
            android:id="@+id/btnOverflow"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_more_vert_white_24dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/cd_more_options"/>

    </LinearLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/tilSearch"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:visibility="gone"
        app:endIconMode="clear_text"
        app:endIconTint="#AAAAAA"
        app:boxBackgroundColor="#1E1E1E"
        app:hintTextColor="#AAAAAA">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etSearch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textColorHint="#AAAAAA"
            android:inputType="text"
            android:imeOptions="actionSearch"
            android:hint="@string/hint_research"
            android:autofillHints="no"/>

    </com.google.android.material.textfield.TextInputLayout>

    <ProgressBar
        android:id="@+id/progressScan"
        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:indeterminate="true"
        android:indeterminateTint="#BB86FC"
        android:visibility="gone"/>

    <!-- TAB LAYOUT -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tabLayout"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="#1E1E1E"
        android:contentDescription="@string/tabs_navigation"
        app:tabTextColor="#AAAAAA"
        app:tabSelectedTextColor="#BB86FC"
        app:tabIndicatorColor="#BB86FC"
        app:tabIndicatorHeight="3dp"
        app:tabMode="fixed"
        app:tabGravity="fill"/>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.viewpager2.widget.ViewPager2
            android:id="@+id/viewPager"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerViewSearch"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#121212"
            android:visibility="gone"/>

    </FrameLayout>

    <!-- MINI PLAYER BAR -->
    <LinearLayout
        android:id="@+id/miniPlayer"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:orientation="horizontal"
        android:background="#1E1E1E"
        android:padding="8dp"
        android:gravity="center_vertical"
        android:visibility="gone">

        <ImageView
            android:id="@+id/miniAlbumArt"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:scaleType="centerCrop"
            android:background="#333333"
            android:contentDescription="@string/cd_album_art"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="8dp">

            <TextView
                android:id="@+id/miniTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:maxLines="1"
                android:ellipsize="end"
                android:text="@string/no_song_playing"/>

            <TextView
                android:id="@+id/miniArtist"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#AAAAAA"
                android:textSize="12sp"
                android:maxLines="1"
                android:ellipsize="end"
                android:text=""/>
        </LinearLayout>

        <ImageButton
            android:id="@+id/miniRandom"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_random_white_24dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/cd_random"/>

        <ImageButton
            android:id="@+id/miniPrevious"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_skip_previous_white_24dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/cd_previous"/>

        <ImageButton
            android:id="@+id/miniPlayPause"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_play_white_24dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/cd_play_pause"/>

        <ImageButton
            android:id="@+id/miniNext"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_skip_next_white_24dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/cd_next"/>

    </LinearLayout>

</LinearLayout>