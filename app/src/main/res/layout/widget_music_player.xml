<?xml version="1.0" encoding="utf-8"?>
<!--
    Layout del widget sulla home screen.
    IMPORTANTE: i widget supportano solo un sottoinsieme di View:
    FrameLayout, LinearLayout, RelativeLayout, GridLayout,
    TextView, ImageView, Button, ImageButton, ProgressBar, Chronometer.
    NON si possono usare RecyclerView, ConstraintLayout, ecc.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="#CC1E1E1E"
    android:padding="8dp"
    android:gravity="center_vertical">

    <!-- Copertina album -->
    <ImageView
        android:id="@+id/widgetAlbumArt"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:scaleType="centerCrop"
        android:background="#333333"
        android:contentDescription="@string/cd_album_art"/>

    <!-- Titolo + artista -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="4dp">

        <TextView
            android:id="@+id/widgetTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/no_song_playing"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end"/>

        <TextView
            android:id="@+id/widgetArtist"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="#AAAAAA"
            android:textSize="11sp"
            android:maxLines="1"
            android:ellipsize="end"/>
    </LinearLayout>

    <!-- Precedente -->
    <ImageButton
            android:id="@+id/widgetPrevious"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_skip_previous_white_24dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/cd_previous"/>

        <!-- Bottone play/pausa -->
        <ImageButton
            android:id="@+id/widgetPlayPause"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_play_white_24dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/cd_play_pause"/>

        <!-- Bottone successivo -->
        <ImageButton
            android:id="@+id/widgetNext"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_skip_next_white_24dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/cd_next"/>

</LinearLayout>
