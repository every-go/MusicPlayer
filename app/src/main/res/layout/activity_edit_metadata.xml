<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_skip_previous_white_24dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/cd_previous"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="@string/title_edit_metadata"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold"/>

            <Button
                android:id="@+id/btnSave"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/action_save"
                android:backgroundTint="#BB86FC"
                android:textColor="#000000"/>

        </LinearLayout>

        <!-- Titolo -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/label_title"
            android:textColor="#AAAAAA"
            android:textSize="12sp"
            android:layout_marginBottom="4dp"/>
        <EditText
            android:id="@+id/etTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:backgroundTint="#BB86FC"
            android:inputType="text"
            android:autofillHints="no"
            android:layout_marginBottom="16dp"/>

        <!-- Artista -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/label_artist"
            android:textColor="#AAAAAA"
            android:textSize="12sp"
            android:layout_marginBottom="4dp"/>
        <EditText
            android:id="@+id/etArtist"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:backgroundTint="#BB86FC"
            android:inputType="text"
            android:autofillHints="no"
            android:layout_marginBottom="16dp"/>

        <!-- Album Artist -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/label_album_artist"
            android:textColor="#AAAAAA"
            android:textSize="12sp"
            android:layout_marginBottom="4dp"/>
        <EditText
            android:id="@+id/etAlbumArtist"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:backgroundTint="#BB86FC"
            android:inputType="text"
            android:autofillHints="no"
            android:layout_marginBottom="16dp"/>

        <!-- Album -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/label_album"
            android:textColor="#AAAAAA"
            android:textSize="12sp"
            android:layout_marginBottom="4dp"/>
        <EditText
            android:id="@+id/etAlbum"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:backgroundTint="#BB86FC"
            android:inputType="text"
            android:autofillHints="no"
            android:layout_marginBottom="16dp"/>

        <!-- Anno -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/label_year"
            android:textColor="#AAAAAA"
            android:textSize="12sp"
            android:layout_marginBottom="4dp"/>
        <EditText
            android:id="@+id/etYear"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:backgroundTint="#BB86FC"
            android:inputType="number"
            android:autofillHints="no"
            android:layout_marginBottom="16dp"/>

        <!-- Numero traccia -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/label_track_number"
            android:textColor="#AAAAAA"
            android:textSize="12sp"
            android:layout_marginBottom="4dp"/>
        <EditText
            android:id="@+id/etTrackNumber"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:backgroundTint="#BB86FC"
            android:inputType="number"
            android:autofillHints="no"
            android:layout_marginBottom="16dp"/>

        <!-- Genere -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/label_genre"
            android:textColor="#AAAAAA"
            android:textSize="12sp"
            android:layout_marginBottom="4dp"/>
        <EditText
            android:id="@+id/etGenre"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:backgroundTint="#BB86FC"
            android:inputType="text"
            android:autofillHints="no"
            android:layout_marginBottom="16dp"/>

    </LinearLayout>

</ScrollView>
